{
  "name": "party-games-online",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter @party/web dev\" \"pnpm --filter @party/server dev\"",
    "dev:web": "pnpm --filter @party/web dev",
    "dev:server": "pnpm --filter @party/server dev",
    "dev:party": "pnpm --filter @party/party dev",
    "build": "pnpm --filter @party/shared build && pnpm --filter @party/game-core build && pnpm --filter @party/game-touchline build && pnpm --filter @party/server build && pnpm --filter @party/web build",
    "deploy:vercel": "vercel --cwd apps/web",
    "test": "pnpm --filter @party/game-touchline test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4"
}
